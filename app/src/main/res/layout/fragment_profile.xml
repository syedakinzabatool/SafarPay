<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:overScrollMode="never">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Profile header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="220dp"
            android:background="@color/colorPrimary" android:orientation="vertical"
            android:gravity="center" android:padding="24dp">

            <!-- Circular avatar -->
            <FrameLayout android:layout_width="88dp" android:layout_height="88dp"
                android:layout_marginBottom="14dp">
                <View android:layout_width="88dp" android:layout_height="88dp"
                    android:background="@drawable/bg_circle_avatar_white"/>
                <TextView android:id="@+id/tvInitial"
                    android:layout_width="match_parent" android:layout_height="match_parent"
                    android:gravity="center" android:text="U"
                    android:textSize="34sp" android:fontFamily="@font/poppins_bold"
                    android:textColor="#FFFFFF"/>
            </FrameLayout>

            <TextView android:id="@+id/tvName"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="User" android:textSize="20sp" android:fontFamily="@font/poppins_bold"
                android:textColor="#FFFFFF"/>

            <TextView android:id="@+id/tvEmail"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="email@example.com" android:textSize="13sp"
                android:fontFamily="@font/inter_regular"
                android:textColor="#B2DFDB" android:layout_marginTop="2dp"/>

            <TextView
                android:id="@+id/tvAccountStatus"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:visibility="gone"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="#FFCDD2"
                android:text="Your account is deactivated. Please contact admin support."/>
        </LinearLayout>

        <!-- Stats row -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="-20dp"
            android:layout_marginBottom="20dp"
            app:cardCornerRadius="16dp" app:cardElevation="6dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="80dp"
                android:orientation="horizontal" android:background="@color/colorSurface">

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvTripCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="26sp" android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/colorPrimary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Trips" android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/colorTextSecondary"/>
                </LinearLayout>

                <View android:layout_width="1dp" android:layout_height="40dp"
                    android:background="@color/colorDivider" android:layout_gravity="center_vertical"/>

                <LinearLayout android:layout_width="0dp" android:layout_height="match_parent"
                    android:layout_weight="1" android:orientation="vertical"
                    android:gravity="center">
                    <TextView android:id="@+id/tvExpenseCount"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="0" android:textSize="26sp" android:fontFamily="@font/poppins_bold"
                        android:textColor="@color/colorPrimary"/>
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="Expenses" android:textSize="12sp"
                        android:fontFamily="@font/inter_regular"
                        android:textColor="@color/colorTextSecondary"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Settings section -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical" android:layout_marginHorizontal="20dp"
            android:layout_marginBottom="16dp">

            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="SETTINGS" android:textSize="11sp" android:textColor="@color/colorTextSecondary"
                android:fontFamily="@font/inter_medium" android:textAllCaps="true"
                android:letterSpacing="0.1" android:layout_marginBottom="10dp"/>

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                app:cardCornerRadius="16dp" app:cardElevation="2dp">

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" android:background="@color/colorSurface">

                    <LinearLayout android:id="@+id/rowConverter"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="36dp" android:layout_height="36dp"
                            android:text="💱" android:textSize="20sp" android:gravity="center"
                            android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="Currency Converter"
                            android:textSize="15sp" android:fontFamily="@font/inter_medium"
                            android:textColor="@color/colorText"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="22sp" android:textColor="@color/colorHint"/>
                    </LinearLayout>

                    <View android:layout_width="match_parent" android:layout_height="1dp"
                        android:background="@color/colorDivider" android:layout_marginHorizontal="20dp"/>

                    <LinearLayout android:id="@+id/rowAbout"
                        android:layout_width="match_parent" android:layout_height="60dp"
                        android:orientation="horizontal" android:gravity="center_vertical"
                        android:paddingHorizontal="20dp"
                        android:background="?attr/selectableItemBackground"
                        android:clickable="true" android:focusable="true">
                        <TextView android:layout_width="36dp" android:layout_height="36dp"
                            android:text="ℹ" android:textSize="20sp" android:gravity="center"
                            android:layout_marginEnd="14dp"/>
                        <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                            android:layout_weight="1" android:text="About SafarPay"
                            android:textSize="15sp" android:fontFamily="@font/inter_medium"
                            android:textColor="@color/colorText"/>
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="›" android:textSize="22sp" android:textColor="@color/colorHint"/>
                    </LinearLayout>

                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- Logout button -->
        <Button android:id="@+id/btnLogout"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:layout_marginHorizontal="20dp" android:layout_marginBottom="8dp"
            android:text="Log Out" android:textColor="@color/colorDanger"
            android:backgroundTint="@color/colorDangerLight"
            android:fontFamily="@font/poppins_medium"
            app:cornerRadius="12dp"/>

        <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="SafarPay v1.0" android:gravity="center"
            android:textSize="12sp" android:fontFamily="@font/inter_regular"
            android:textColor="@color/colorHint" android:layout_marginBottom="28dp"/>

    </LinearLayout>
</ScrollView>
