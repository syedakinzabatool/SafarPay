<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="16dp"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header row: name + active badge -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvItemTripName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:textSize="16sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/colorText"/>

            <TextView
                android:id="@+id/tvActiveBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textSize="10sp"
                android:fontFamily="@font/poppins_medium"
                android:textColor="#FFFFFF"
                android:background="@color/colorPrimary"
                android:paddingHorizontal="8dp"
                android:paddingVertical="3dp"
                android:visibility="gone"/>
        </LinearLayout>

        <TextView
            android:id="@+id/tvItemDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/colorPrimary"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvItemDates"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/colorTextSecondary"
            android:layout_marginTop="2dp"/>

        <TextView
            android:id="@+id/tvItemBudget"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="13sp"
            android:fontFamily="@font/inter_medium"
            android:textColor="@color/colorText"
            android:layout_marginTop="4dp"/>

        <!-- Action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <Button
                android:id="@+id/btnSetActive"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Set Active"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/colorPrimary"
                app:strokeColor="@color/colorPrimary"
                app:cornerRadius="8dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnEditBudget"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Edit Budget"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/colorPrimary"
                app:strokeColor="@color/colorPrimary"
                app:cornerRadius="8dp"
                android:layout_marginEnd="6dp"/>

            <Button
                android:id="@+id/btnDeleteTrip"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Delete"
                android:textSize="12sp"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="@color/colorError"
                app:strokeColor="@color/colorError"
                app:cornerRadius="8dp"/>

        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>