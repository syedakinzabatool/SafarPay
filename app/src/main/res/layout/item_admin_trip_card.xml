<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginTop="6dp"
    android:layout_marginBottom="4dp"
    app:cardCornerRadius="16dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="@color/colorSurface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tvTripName"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Business Trip"
                android:textSize="17sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/colorText" />

            <TextView
                android:id="@+id/tvTripStatusBadge"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textSize="10sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/colorText"
                android:paddingHorizontal="10dp"
                android:paddingVertical="5dp"
                android:textAllCaps="true"
                android:background="@drawable/bg_pill_success" />
        </LinearLayout>

        <TextView
            android:id="@+id/tvTripDestination"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Destination: Malaysia"
            android:textSize="12sp"
            android:fontFamily="@font/inter_regular"
            android:textColor="@color/colorTextSecondary" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="10dp">

            <TextView
                android:id="@+id/tvTripOwner"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Owner: user@email.com"
                android:textSize="12sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="@color/colorTextSecondary" />

            <TextView
                android:id="@+id/tvTripBudget"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="PKR 50000"
                android:textSize="15sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/colorPrimary" />
        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>
