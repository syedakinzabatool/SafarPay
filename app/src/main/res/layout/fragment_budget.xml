<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent" android:layout_height="match_parent"
    android:background="@color/colorBackground"
    android:overScrollMode="never">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@color/colorPrimary"
            android:paddingStart="24dp" android:paddingEnd="24dp"
            android:paddingTop="20dp" android:paddingBottom="36dp"
            android:orientation="vertical">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Budget" android:textSize="22sp"
                android:fontFamily="@font/poppins_bold" android:textColor="#FFFFFF"/>
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Breakdown by category" android:textSize="13sp"
                android:fontFamily="@font/inter_regular" android:textColor="#B2DFDB"
                android:layout_marginTop="2dp"/>
        </LinearLayout>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/bg_rounded_white"
            android:layout_marginTop="-20dp"
            android:paddingTop="24dp" android:paddingBottom="24dp">

            <!-- Export button -->
            <Button
                android:id="@+id/btnExportPDF"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                android:text="📥 Download as PDF"
                android:textAllCaps="false"
                android:textSize="14sp"
                android:fontFamily="@font/inter_medium"
                android:textColor="#FFFFFF"
                android:backgroundTint="@color/colorPrimary"
                app:cornerRadius="12dp"/>

            <!-- Warning banner -->
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:background="@color/colorWarning"
                android:paddingHorizontal="20dp" android:paddingVertical="14dp"
                android:orientation="horizontal" android:gravity="center_vertical"
                android:layout_marginHorizontal="20dp" android:layout_marginBottom="16dp"
                android:visibility="gone">
                <!-- Outer view acts as container since CardView can't be gone -->
            </LinearLayout>
            <TextView android:id="@+id/tvWarning" android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorWarning"
                android:text="⚠ You have spent 80%+ of your budget!"
                android:paddingHorizontal="20dp" android:paddingVertical="14dp"
                android:textColor="#FFFFFF" android:fontFamily="@font/inter_medium"
                android:visibility="gone" android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Budget summary card -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent" android:layout_height="wrap_content"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"
                app:cardCornerRadius="16dp" app:cardElevation="3dp"
                app:cardBackgroundColor="@color/colorBackground">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:padding="20dp">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Budget" android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="@color/colorTextSecondary" android:textAllCaps="true"
                            android:letterSpacing="0.05"/>
                        <TextView android:id="@+id/tvTotalBudget" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="PKR 0"
                            android:textSize="16sp" android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/colorText" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp"
                        android:background="@color/colorDivider" android:layout_gravity="center_vertical"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Spent" android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="@color/colorTextSecondary" android:textAllCaps="true"
                            android:letterSpacing="0.05"/>
                        <TextView android:id="@+id/tvTotalSpent" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="PKR 0"
                            android:textSize="16sp" android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/colorWarning" android:layout_marginTop="4dp"/>
                    </LinearLayout>

                    <View android:layout_width="1dp" android:layout_height="40dp"
                        android:background="@color/colorDivider" android:layout_gravity="center_vertical"/>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:orientation="vertical" android:gravity="center">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                            android:text="Left" android:textSize="11sp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="@color/colorTextSecondary" android:textAllCaps="true"
                            android:letterSpacing="0.05"/>
                        <TextView android:id="@+id/tvRemaining" android:layout_width="wrap_content"
                            android:layout_height="wrap_content" android:text="PKR 0"
                            android:textSize="16sp" android:fontFamily="@font/poppins_bold"
                            android:textColor="@color/colorSuccess" android:layout_marginTop="4dp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Pie chart -->
            <com.github.mikephil.charting.charts.PieChart android:id="@+id/pieChart"
                android:layout_width="match_parent" android:layout_height="250dp"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="20dp"/>

            <!-- Category bars section -->
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="By Category" android:textSize="16sp"
                android:fontFamily="@font/poppins_bold"
                android:textColor="@color/colorText"
                android:layout_marginHorizontal="20dp"
                android:layout_marginBottom="12dp"/>

            <LinearLayout android:id="@+id/llCategoryBars" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:layout_marginHorizontal="20dp"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
