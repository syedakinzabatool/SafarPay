<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="210dp"
    android:background="@color/colorPrimary"
    android:orientation="vertical"
    android:padding="20dp"
    android:gravity="bottom">

    <FrameLayout
        android:layout_width="64dp"
        android:layout_height="64dp"
        android:layout_marginBottom="14dp">

        <View
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_circle_avatar_white"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="✈"
            android:textSize="26sp"
            android:gravity="center"
            android:textColor="#FFFFFF"/>
    </FrameLayout>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SafarPay"
        android:textSize="22sp"
        android:textColor="#FFFFFF"
        android:fontFamily="@font/poppins_bold"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Admin Control Center"
        android:textSize="12sp"
        android:textColor="#B2DFDB"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="2dp"/>

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Manage users, trips, analytics and notices"
        android:textSize="11sp"
        android:textColor="#D4F1ED"
        android:fontFamily="@font/inter_regular"
        android:layout_marginTop="8dp"/>
</LinearLayout>
