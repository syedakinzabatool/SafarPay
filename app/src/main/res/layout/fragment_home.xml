<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/colorBackground">

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:overScrollMode="never">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Header -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorPrimary"
                android:orientation="vertical"
                android:paddingStart="24dp"
                android:paddingEnd="24dp"
                android:paddingTop="20dp"
                android:paddingBottom="36dp">

                <TextView
                    android:id="@+id/tvWelcomeMessage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Welcome back"
                    android:textSize="22sp"
                    android:fontFamily="@font/poppins_bold"
                    android:textColor="#FFFFFF"
                    android:maxLines="1"
                    android:ellipsize="end"/>
            </LinearLayout>

            <!-- Notice -->
            <LinearLayout
                android:id="@+id/bannerNotice"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/colorWarning"
                android:padding="14dp"
                android:orientation="horizontal"
                android:layout_marginHorizontal="16dp"
                android:layout_marginTop="-4dp">

                <TextView
                    android:id="@+id/tvNotice"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textColor="#FFFFFF"
                    android:textSize="13sp"
                    android:fontFamily="@font/inter_regular"/>

                <ImageButton
                    android:id="@+id/btnDismissNotice"
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@android:drawable/ic_menu_close_clear_cancel"
                    android:tint="#FFFFFF"
                    android:contentDescription="Dismiss notice"
                    android:layout_marginStart="8dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:layout_marginTop="-20dp"
                android:paddingBottom="96dp">

                <!-- No trip -->
                <TextView
                    android:id="@+id/tvNoTrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="No active trip. Create one!"
                    android:gravity="center"
                    android:textSize="15sp"
                    android:padding="40dp"
                    android:textColor="@color/colorTextSecondary"
                    android:fontFamily="@font/inter_regular"
                    android:visibility="gone"/>

                <!-- Card -->
                <androidx.cardview.widget.CardView
                    android:id="@+id/cardTrip"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="20dp"
                    app:cardElevation="6dp"
                    android:layout_marginBottom="16dp">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">

                        <!-- Title Row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal"
                            android:gravity="center_vertical"
                            android:layout_marginBottom="8dp">

                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical">

                                <TextView
                                    android:id="@+id/tvTripName"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="20sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:textColor="@color/colorText"
                                    android:text="Trip Name"/>

                                <TextView
                                    android:id="@+id/tvDestination"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:textSize="13sp"
                                    android:fontFamily="@font/inter_regular"
                                    android:textColor="@color/colorPrimary"
                                    android:text="Destination"/>
                            </LinearLayout>
                        </LinearLayout>

                        <TextView
                            android:id="@+id/tvDates"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textSize="12sp"
                            android:fontFamily="@font/inter_regular"
                            android:textColor="@color/colorTextSecondary"
                            android:layout_marginBottom="16dp"
                            android:text="Dates"/>

                        <ProgressBar
                            android:id="@+id/progressBudget"
                            style="?android:attr/progressBarStyleHorizontal"
                            android:layout_width="match_parent"
                            android:layout_height="8dp"
                            android:max="100"
                            android:progress="0"
                            android:layout_marginBottom="16dp"
                            android:progressTint="@color/colorPrimary"
                            android:progressBackgroundTint="@color/colorPrimaryLight"/>

                        <!-- Stats -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal">

                            <!-- Spent -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@color/colorBackground"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Spent"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/inter_regular"
                                    android:textColor="@color/colorTextSecondary"/>

                                <TextView
                                    android:id="@+id/tvSpent"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PKR 0"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:textColor="@color/colorText"/>
                            </LinearLayout>

                            <View android:layout_width="8dp" android:layout_height="0dp"/>

                            <!-- Remaining -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@color/colorSuccessLight"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Remaining"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/inter_regular"
                                    android:textColor="@color/colorTextSecondary"/>

                                <TextView
                                    android:id="@+id/tvRemaining"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="PKR 0"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:textColor="@color/colorSuccess"/>
                            </LinearLayout>

                            <View android:layout_width="8dp" android:layout_height="0dp"/>

                            <!-- FIXED -->
                            <LinearLayout
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1"
                                android:orientation="vertical"
                                android:gravity="center"
                                android:background="@color/colorPrimaryLight"
                                android:padding="12dp">

                                <TextView
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="Days Left"
                                    android:textSize="11sp"
                                    android:fontFamily="@font/inter_regular"
                                    android:textColor="@color/colorTextSecondary"/>

                                <TextView
                                    android:id="@+id/tvDaysLeftStats"
                                    android:layout_width="wrap_content"
                                    android:layout_height="wrap_content"
                                    android:text="0"
                                    android:textSize="15sp"
                                    android:fontFamily="@font/poppins_bold"
                                    android:textColor="@color/colorPrimary"/>
                            </LinearLayout>
                        </LinearLayout>

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Button -->
                <Button
                    android:id="@+id/btnNewTrip"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="+ Start New Trip"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:fontFamily="@font/poppins_medium"
                    android:textColor="@color/colorPrimary"
                    app:strokeColor="@color/colorPrimary"
                    app:cornerRadius="12dp"/>

                <Button
                    android:id="@+id/btnMyTrips"
                    android:layout_width="match_parent"
                    android:layout_height="52dp"
                    android:text="My Trips"
                    android:layout_marginTop="8dp"
                    style="@style/Widget.MaterialComponents.Button"
                    android:backgroundTint="@color/colorPrimary"
                    android:textColor="#FFFFFF"
                    android:fontFamily="@font/poppins_medium"
                    app:cornerRadius="12dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>

    <!-- FAB -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fabAddExpense"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="20dp"
        android:src="@android:drawable/ic_input_add"
        app:backgroundTint="@color/colorPrimary"
        app:fabSize="normal"
        android:layout_gravity="bottom|end"/>

</androidx.coordinatorlayout.widget.CoordinatorLayout>